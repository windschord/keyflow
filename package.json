{
  "name": "keyflow",
  "version": "0.1.0",
  "description": "MusicXML対応ピアノ練習アプリ",
  "license": "Apache-2.0",
  "main": "out/main/index.js",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "predev": "npm run generate:licenses",
    "dev": "electron-vite dev",
    "prebuild": "npm run generate:licenses",
    "build": "npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "prelint": "npm run generate:licenses",
    "lint": "eslint src",
    "lint:jp:md": "textlint --config .textlintrc.json \"docs/**/*.md\"",
    "lint:jp:ts": "node scripts/lint-jp-ts-comments.mjs",
    "lint:jp": "npm run lint:jp:md && npm run lint:jp:ts",
    "generate:icons": "node scripts/generate-icons.mjs",
    "generate:licenses": "node scripts/generate-licenses.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pretest": "npm run generate:licenses",
    "test": "vitest run --passWithNoTests",
    "pretest:coverage": "npm run generate:licenses",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:e2e": "npm run build && playwright test",
    "test:packaged": "node scripts/smoke-packaged-app.mjs",
    "playwright:install": "playwright install chromium",
    "postinstall": "node node_modules/electron/install.js"
  },
  "dependencies": {
    "conf": "^15.1.0",
    "electron-store": "^8.2.0",
    "fast-xml-parser": "^5.9.3",
    "fflate": "^0.8.3",
    "opensheetmusicdisplay": "^2.0.0",
    "tone": "^15.1.22",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^42.6.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^29.1.1",
    "png2icons": "^2.0.1",
    "prettier": "^3.9.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "textlint": "^15.7.1",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  }
}
