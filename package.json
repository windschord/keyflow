{
  "name": "musicxml-practice-app",
  "version": "0.1.0",
  "description": "MusicXML対応ピアノ練習アプリ",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "lint": "eslint src",
    "lint:jp:md": "textlint --config .textlintrc.json \"docs/**/*.md\"",
    "lint:jp:ts": "node scripts/lint-jp-ts-comments.mjs",
    "lint:jp": "npm run lint:jp:md && npm run lint:jp:ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "postinstall": "node node_modules/electron/install.js"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "fast-xml-parser": "^5.9.3",
    "fflate": "^0.8.3",
    "midi": "^2.0.0",
    "opensheetmusicdisplay": "^2.0.0",
    "zustand": "^4.5.7"
  },
  "overrides": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/midi": "^2.0.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.0.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "textlint": "^13.4.0",
    "textlint-rule-preset-ja-technical-writing": "^10.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.21",
    "vitest": "^3.0.0"
  }
}
